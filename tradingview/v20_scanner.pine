// V20 Signal Scanner — TradingView Pine Script v6
// Exact port of live_scanner.py logic
// 4H BTC/USDT only
//
// Indicators: TD Sequential, MACD(13,34,9) Divergence, Fibonacci, SMA200, ATR(14)
// Signal tiers: T1(20x) through T6(5x)

//@version=6
indicator("V20 Scanner", overlay=true, max_labels_count=500, max_lines_count=500)

// ══════════════════════════════════════════════════════════════════════
// CONSTANTS — match live_scanner.py exactly
// ══════════════════════════════════════════════════════════════════════

MACD_FAST     = 13
MACD_SLOW     = 34
MACD_SIGNAL   = 9
ATR_PERIOD    = 14
SMA_PERIOD    = 200
SWING_LOOKBACK = 20
FIB_TOL       = 0.012    // 1.2%
DIV_LOOKBACK  = 120
VOL_THRESHOLD = 0.8      // 80% of 20-bar avg

// ══════════════════════════════════════════════════════════════════════
// CORE INDICATORS
// ══════════════════════════════════════════════════════════════════════

sma200 = ta.sma(close, SMA_PERIOD)
plot(sma200, "SMA200", color=color.new(color.orange, 30), linewidth=2)

atrVal = ta.atr(ATR_PERIOD)

// MACD — EMA-based, matching Python compute_ema (adjust=False → standard EMA)
macdLine   = ta.ema(close, MACD_FAST) - ta.ema(close, MACD_SLOW)
signalLine = ta.ema(macdLine, MACD_SIGNAL)
macdHist   = macdLine - signalLine

// Volume
avgVol = ta.sma(volume, 20)
volOk  = volume > avgVol * VOL_THRESHOLD
volSpike = volume > avgVol * 1.5

// ══════════════════════════════════════════════════════════════════════
// TD SEQUENTIAL — exact port of compute_td_sequential
// ══════════════════════════════════════════════════════════════════════

// Buy setup: close < close[4] increments, close > close[4] resets to sell, equal resets both
var int buySetup  = 0
var int sellSetup = 0

if bar_index >= 4
    if close < close[4]
        buySetup  := buySetup > 0 ? buySetup + 1 : 1
        sellSetup := 0
    else if close > close[4]
        sellSetup := sellSetup > 0 ? sellSetup + 1 : 1
        buySetup  := 0
    else
        buySetup  := 0
        sellSetup := 0

// Buy countdown: after buy setup hits 9, count bars where close <= low[2]
// Cancel on sell_setup >= 4 or countdown reaches 13
var bool buyCdActive = false
var int  buyCdCount  = 0
var int  buyCdDisplay = 0  // per-bar countdown value

if buySetup == 9
    buyCdActive := true
    buyCdCount  := 0

// Sell countdown
var bool sellCdActive = false
var int  sellCdCount  = 0
var int  sellCdDisplay = 0

if sellSetup == 9
    sellCdActive := true
    sellCdCount  := 0

buyCdDisplay := 0
if buyCdActive and bar_index >= 2
    if close <= low[2]
        buyCdCount  += 1
        buyCdDisplay := buyCdCount
    if buyCdCount >= 13
        buyCdActive := false
        buyCdCount  := 0
    if sellSetup >= 4
        buyCdActive := false
        buyCdCount  := 0

sellCdDisplay := 0
if sellCdActive and bar_index >= 2
    if close >= high[2]
        sellCdCount  += 1
        sellCdDisplay := sellCdCount
    if sellCdCount >= 13
        sellCdActive := false
        sellCdCount  := 0
    if buySetup >= 4
        sellCdActive := false
        sellCdCount  := 0

// Plot TD counts on chart
// Buy setup: show 7, 8, 9+ below candles (green)
plotchar(buySetup == 7, "TD7↓", "7", location.belowbar, color=color.new(color.green, 30), size=size.tiny)
plotchar(buySetup == 8, "TD8↓", "8", location.belowbar, color=color.new(color.green, 20), size=size.tiny)
plotchar(buySetup >= 9, "TD9↓", "9", location.belowbar, color=color.new(color.green, 0), size=size.small)

plotchar(sellSetup == 7, "TD7↑", "7", location.abovebar, color=color.new(color.red, 30), size=size.tiny)
plotchar(sellSetup == 8, "TD8↑", "8", location.abovebar, color=color.new(color.red, 20), size=size.tiny)
plotchar(sellSetup >= 9, "TD9↑", "9", location.abovebar, color=color.new(color.red, 0), size=size.small)

// Countdown markers
plotchar(buyCdDisplay == 13, "TD13↓", "★", location.belowbar, color=color.lime, size=size.normal)
plotchar(buyCdDisplay > 0 and buyCdDisplay < 13, "BuyCD", "", location.belowbar, color=color.new(color.green, 60), size=size.tiny)

// ══════════════════════════════════════════════════════════════════════
// SWING POINTS & FIBONACCI
// ══════════════════════════════════════════════════════════════════════

// Pine's pivothigh/low with lookback acts similarly to find_swing_points
// It confirms a pivot only after SWING_LOOKBACK bars pass (delayed, like Python's i < idx - 5)
swingHigh = ta.pivothigh(high, SWING_LOOKBACK, SWING_LOOKBACK)
swingLow  = ta.pivotlow(low, SWING_LOOKBACK, SWING_LOOKBACK)

var float lastSwingHigh = na
var float lastSwingLow  = na

if not na(swingHigh)
    lastSwingHigh := swingHigh

if not na(swingLow)
    lastSwingLow := swingLow

// Fib levels from last swing high/low
fibValid = not na(lastSwingHigh) and not na(lastSwingLow) and lastSwingHigh != lastSwingLow
fibDiff  = fibValid ? lastSwingHigh - lastSwingLow : 0.0

fib382 = fibValid ? lastSwingHigh - fibDiff * 0.382 : na
fib500 = fibValid ? lastSwingHigh - fibDiff * 0.500 : na
fib618 = fibValid ? lastSwingHigh - fibDiff * 0.618 : na
fib786 = fibValid ? lastSwingHigh - fibDiff * 0.786 : na
fibExt1272 = fibValid ? lastSwingLow + fibDiff * 1.272 : na
fibExt1618 = fibValid ? lastSwingLow + fibDiff * 1.618 : na

// Plot key Fib levels
plot(fib382, "Fib 0.382", color=color.new(color.gray, 60), style=plot.style_circles)
plot(fib500, "Fib 0.500", color=color.new(color.yellow, 50), style=plot.style_circles)
plot(fib618, "Fib 0.618", color=color.new(color.blue, 40), style=plot.style_circles)

// Check price near key Fib levels (within tolerance) — checks 0.618 first like Python
nearFib618 = fibValid and math.abs(close - fib618) / close <= FIB_TOL
nearFib500 = fibValid and math.abs(close - fib500) / close <= FIB_TOL
nearFib382 = fibValid and math.abs(close - fib382) / close <= FIB_TOL
nearFib = nearFib618 or nearFib500 or nearFib382

// ══════════════════════════════════════════════════════════════════════
// MACD BULLISH DIVERGENCE — port of check_bottom_divergence
// Tracks histogram troughs: price lower low + histogram higher trough = divergence
// ══════════════════════════════════════════════════════════════════════

var float trough1Val = na   // older trough histogram value
var int   trough1Idx = na   // older trough bar_index
var float trough1Low = na   // price low at older trough
var float trough2Val = na   // newer trough histogram value
var int   trough2Idx = na   // newer trough bar_index
var float trough2Low = na   // price low at newer trough
var bool  inTrough   = false
var float curTroughVal = 0.0
var int   curTroughIdx = 0
var float curTroughLow = 0.0

if macdHist < 0
    if not inTrough
        curTroughVal := macdHist
        curTroughIdx := bar_index
        curTroughLow := low
        inTrough := true
    else if macdHist < curTroughVal
        curTroughVal := macdHist
        curTroughIdx := bar_index
        curTroughLow := low
    // Track lowest price during entire trough period
    if low < curTroughLow
        curTroughLow := low
else
    if inTrough and curTroughVal < 0
        // Shift: newest becomes older, current becomes newest
        trough1Val := trough2Val
        trough1Idx := trough2Idx
        trough1Low := trough2Low
        trough2Val := curTroughVal
        trough2Idx := curTroughIdx
        trough2Low := curTroughLow
    inTrough := false
    curTroughVal := 0.0

// Divergence: price made lower low but histogram trough is higher (less negative)
bullDiv = not na(trough1Val) and not na(trough2Val) and
     not na(trough1Idx) and not na(trough2Idx) and
     trough2Idx > trough1Idx and
     bar_index - trough1Idx < DIV_LOOKBACK and
     trough2Low < trough1Low and trough2Val > trough1Val

// ══════════════════════════════════════════════════════════════════════
// SIGNAL DETECTION — exact tier logic from detect_signal (with >= 9 fix)
// ══════════════════════════════════════════════════════════════════════

hasTd9  = buySetup >= 9
hasTd13 = buyCdDisplay >= 13
hasDiv  = bullDiv
hasFib  = nearFib

// Tier priority matches Python if/elif chain exactly
tier1 = volOk and hasTd13 and hasFib                          // 20x
tier2 = volOk and hasTd9  and hasDiv and not tier1             // 20x
tier3 = volOk and hasTd9  and hasFib and not tier1 and not tier2  // 10x
tier4 = volOk and hasTd13 and not tier1 and not tier2 and not tier3  // 10x
tier5 = volOk and hasTd9  and volSpike and not tier1 and not tier2 and not tier3 and not tier4  // 5x
tier6 = volOk and hasDiv  and hasFib and not tier1 and not tier2 and not tier3 and not tier4 and not tier5  // 5x

signalFired = tier1 or tier2 or tier3 or tier4 or tier5 or tier6

tierLabel = tier1 ? "T1·20x" : tier2 ? "T2·20x" : tier3 ? "T3·10x" : tier4 ? "T4·10x" : tier5 ? "T5·5x" : tier6 ? "T6·5x" : ""

// ══════════════════════════════════════════════════════════════════════
// VISUAL OUTPUT
// ══════════════════════════════════════════════════════════════════════

// Signal marker — green diamond below bar
plotshape(signalFired, "⚡ SIGNAL", shape.diamond, location.belowbar, 
     color=color.lime, size=size.normal)

// Tier label below signal
if signalFired
    label.new(bar_index, low, tierLabel, 
         style=label.style_label_up, color=color.new(color.green, 20), 
         textcolor=color.white, size=size.small)

// Background hints
bgcolor(not volOk ? color.new(color.red, 93) : na, title="Low Volume")
bgcolor(bullDiv ? color.new(color.green, 93) : na, title="Bull Divergence")

// ══════════════════════════════════════════════════════════════════════
// INFO TABLE — current state at a glance (top right)
// ══════════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.top_right, 2, 8, 
     bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "V20 Scanner", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, timeframe.period == "240" ? "4H ✅" : "⚠️ " + timeframe.period, 
         text_color=timeframe.period == "240" ? color.green : color.red, text_size=size.small)
    
    table.cell(infoTable, 0, 1, "TD Buy Setup", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 1, str.tostring(buySetup) + "/9", 
         text_color=buySetup >= 9 ? color.lime : buySetup >= 7 ? color.yellow : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 2, "TD Countdown", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 2, str.tostring(buyCdDisplay) + "/13", 
         text_color=buyCdDisplay >= 13 ? color.lime : buyCdDisplay > 0 ? color.yellow : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 3, "MACD Div", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 3, bullDiv ? "YES ✨" : "NO", 
         text_color=bullDiv ? color.lime : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 4, "Near Fib", text_color=color.gray, text_size=size.tiny)
    fibStr = nearFib618 ? "0.618" : nearFib500 ? "0.500" : nearFib382 ? "0.382" : "—"
    table.cell(infoTable, 1, 4, fibStr, 
         text_color=nearFib ? color.lime : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 5, "Volume", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 5, volOk ? (volSpike ? "SPIKE 📈" : "OK") : "LOW ⚠️", 
         text_color=volSpike ? color.lime : volOk ? color.green : color.red, text_size=size.tiny)
    
    table.cell(infoTable, 0, 6, "Trend", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 6, close > sma200 ? "BULL 📈" : "BEAR 📉", 
         text_color=close > sma200 ? color.green : color.red, text_size=size.tiny)
    
    table.cell(infoTable, 0, 7, "Signal", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 7, signalFired ? "⚡ " + tierLabel : "—", 
         text_color=signalFired ? color.lime : color.gray, text_size=size.tiny)
